{
    "name": "caphouse",
    "dockerComposeFile": "docker-compose.yml",
    "service": "dev",
    "workspaceFolder": "/workspace",
    "remoteUser": "vscode",
    "features": {
        "ghcr.io/devcontainers/features/docker-in-docker:2": {
            "moby": false
        }
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "golang.go",
                "anthropic.claude-code"
            ],
            "settings": {
                "go.toolsManagement.autoUpdate": true,
                "go.testTimeout": "120s"
            }
        }
    },
    "postCreateCommand": {
        "Install language server": "go install golang.org/x/tools/gopls@latest",
        "Install `caphouse` to PATH": "go install ./... && caphouse install-scripts"
    },
    "remoteEnv": {
        "GOPATH": "/go"
    },
    "forwardPorts": [
        8081,
        8088
    ],
    "portsAttributes": {
        "8081": {
            "label": "caphouse-api"
        },
        "8080": {
            "label": "caphouse-ui",
            "onAutoForward": "openBrowser"
        }
    }
}